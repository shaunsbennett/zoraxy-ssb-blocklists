async function autoCreatePluginTag(tag){
  setStatus(`Creating tag ${tag}...`);
  try {
    const csrfToken = getCsrfToken();
    if(!csrfToken) throw new Error('CSRF token unavailable; reload the Zoraxy admin page');
    const body = new URLSearchParams({plugin_id:'ssb-blocklists', tag});
    const r = await fetch('/api/plugins/groups/add',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded','X-CSRF-Token':csrfToken},body});
    if(!r.ok) throw new Error(await r.text());
    const data = await r.json().catch(()=>({}));
    if(data.error) throw new Error(data.error);
    setStatus(`Created tag ${tag}`);
    await loadAssociations();
  } catch (err) {
    setStatus(`Create tag failed: ${err.message || err}`, true);
  }
