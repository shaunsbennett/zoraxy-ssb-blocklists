function fmtEvent(e){
  if(!e) return '';
  const t = e.time ? new Date(e.time*1000).toISOString() : '';
  return `${t} ${e.ip || 'unknown'} ${e.host || ''}${e.uri || ''}`;
}
function renderStats(stats){
  document.getElementById('statDrop').textContent = stats.drop_total ?? 0;
  document.getElementById('statPass').textContent = stats.pass_total ?? 0;
  document.getElementById('statSniff').textContent = stats.sniff_total ?? 0;
  document.getElementById('statUnknown').textContent = stats.unknown_ip_total ?? 0;
  document.getElementById('statErrors').textContent = stats.error_total ?? 0;
  document.getElementById('statLoaded').textContent = stats.loaded_entries ?? 0;
  const lastDrop = fmtEvent(stats.last_drop);
  const lastPass = fmtEvent(stats.last_pass);
  document.getElementById('lastDecision').textContent = [lastDrop && `Last drop: ${lastDrop}`, lastPass && `Last pass: ${lastPass}`].filter(Boolean).join(' | ');
}
function render(total){
  document.getElementById('summary').textContent = `${cfg.sources.length} sources, ${total ?? 0} merged entries`;
  document.getElementById('rows').innerHTML = cfg.sources.map((s,i)=>`
    <tr>
      <td><input type="checkbox" ${s.enabled?'checked':''} onchange="cfg.sources[${i}].enabled=this.checked"></td>
      <td><input value="${esc(s.name)}" onchange="cfg.sources[${i}].name=this.value"></td>
      <td><input value="${esc(s.url)}" onchange="cfg.sources[${i}].url=this.value"></td>
      <td><select onchange="cfg.sources[${i}].format=this.value">
        ${['auto','plain','ndjson','json'].map(f=>`<option ${s.format===f?'selected':''}>${f}</option>`).join('')}
      </select></td>
      <td><input class="small" type="number" min="1" value="${esc(s.interval_hours)}" onchange="cfg.sources[${i}].interval_hours=Number(this.value)||1"></td>
      <td>${esc(s.entry_count||0)}</td>
      <td class="status">${esc(s.last_fetch?new Date(s.last_fetch*1000).toISOString():'')}</td>
      <td class="status ${s.last_status==='error'?'danger':''}">${esc(s.last_status||'never')}<br><span class="muted">${esc(s.last_error||'')}</span></td>
      <td><button type="button" onclick="viewEntries(${i})">View</button> <button type="button" onclick="removeSource(${i})">Delete</button></td>
    </tr>`).join('');
}
function addSource(){
  cfg.sources.push({id:id(),name:'New source',url:'',format:'auto',interval_hours:24,enabled:true});
  render();
}
function removeSource(i){cfg.sources.splice(i,1);render()}
async function viewEntries(i){
  const source = cfg.sources[i];
  const box = document.getElementById('entries');
  box.hidden = false;
  box.value = 'Loading entries...';
  try {
    const r = await fetch(apiBase + 'api/source?id=' + encodeURIComponent(source.id));
    if(!r.ok) throw new Error(await r.text());
    const data = await r.json();
    box.value = data.entries.length ? data.entries.join('\\n') : 'No cached entries for this source. Refresh it first.';
    setStatus(`${source.name}: ${data.count} cached entries`);
  } catch (err) {
    box.value = '';
    setStatus(`View failed: ${err.message || err}`, true);
  }
}
async function save(){
  setStatus('Saving...');
  try {
    const csrfToken = getCsrfToken();
    if(!csrfToken) throw new Error('CSRF token unavailable; reload the Zoraxy admin page');
    const r = await fetch(apiBase + 'api/config',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':csrfToken},body:JSON.stringify(cfg)});
    if(!r.ok) throw new Error(await r.text());
    setStatus(`Saved ${new Date().toLocaleTimeString()}`);
    await load();
    return true;
  } catch (err) {
    setStatus(`Save failed: ${err.message || err}`, true);
    return false;
  }
}
async function refreshNow(){
  if(!await save()) return;
  setStatus('Refreshing...');
  try {
    const csrfToken = getCsrfToken();
    if(!csrfToken) throw new Error('CSRF token unavailable; reload the Zoraxy admin page');
    const r = await fetch(apiBase + 'api/refresh',{method:'POST',headers:{'X-CSRF-Token':csrfToken}});
    if(!r.ok) throw new Error(await r.text());
    setStatus(`Refreshed ${new Date().toLocaleTimeString()}`);
    await load();
  } catch (err) {
    setStatus(`Refresh failed: ${err.message || err}`, true);
  }
}
load();
</script>
