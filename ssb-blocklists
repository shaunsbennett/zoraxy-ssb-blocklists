def plugin_dir():
    return Path(os.path.realpath(sys.argv[0])).parent


def iso(ts):
    if not ts:
        return ""
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(ts))


def parse_config_arg():
    for idx, arg in enumerate(sys.argv):
        if arg == "-introspect":
            payload = {
                "id": PLUGIN_ID,
                "name": PLUGIN_NAME,
                "author": "Sermo",
                "author_contact": "",
                "description": "Import URL blocklists and block matching client IPs.",
                "url": "",
                "type": 0,
                "version_major": VERSION[0],
                "version_minor": VERSION[1],
                "version_patch": VERSION[2],
                "dynamic_capture_sniff": DYNAMIC_SNIFF,
                "dynamic_capture_ingress": DYNAMIC_INGRESS,
                "ui_path": UI_PATH,
            }
            print(json.dumps(payload, indent=2))
            sys.exit(0)
        if arg.startswith("-configure="):
            return json.loads(arg[len("-configure="):])
        if arg == "-configure" and idx + 1 < len(sys.argv):
            return json.loads(sys.argv[idx + 1])
    raise SystemExit("missing -configure payload")


def default_config():
    return {
        "settings": {
            "user_agent": f"{PLUGIN_ID}/{VERSION[0]}.{VERSION[1]}.{VERSION[2]}",
            "block_status": 403,
            "client_ip_headers": [],
        },
        "sources": [],
    }


def load_config():
    path = STATE["config_path"]
    if not path.exists():
        cfg = default_config()
        save_config(cfg)
        return cfg
    with path.open("r", encoding="utf-8") as handle:
        cfg = json.load(handle)
    cfg.setdefault("settings", {})
    cfg.setdefault("sources", [])
    cfg["settings"].setdefault("user_agent", default_config()["settings"]["user_agent"])
    cfg["settings"].setdefault("block_status", 403)
    cfg["settings"].setdefault("client_ip_headers", [])
    return cfg


def save_config(cfg):
    path = STATE["config_path"]
    tmp = path.with_suffix(".tmp")
    with tmp.open("w", encoding="utf-8") as handle:
        json.dump(cfg, handle, indent=2, sort_keys=True)
        handle.write("\n")
    os.replace(tmp, path)


def clean_source(src):
    src = dict(src)
    src.setdefault("id", str(now()))
    src.setdefault("name", src.get("url", "Source"))
    src.setdefault("url", "")
    src.setdefault("format", "auto")
    src.setdefault("interval_hours", 24)
    src.setdefault("enabled", True)
    src.setdefault("last_fetch", 0)
    src.setdefault("next_fetch", 0)
    src.setdefault("last_status", "never")
    src.setdefault("last_error", "")
    src.setdefault("entry_count", 0)
    src["interval_hours"] = max(1, int(src.get("interval_hours") or 1))
    return src


def source_cache_path(source_id):
    return STATE["cache_dir"] / f"{source_id}.cidr"


def zoraxy_conf_dir():
    return plugin_dir().parent.parent / "config" / "conf"


def load_json_file(path, fallback):
    try:
        if not path.exists():
            return fallback
        with path.open("r", encoding="utf-8") as handle:
            return json.load(handle)
    except Exception:
        return fallback


def zoraxy_associations():
    conf_dir = zoraxy_conf_dir()
    plugin_groups = load_json_file(conf_dir / "plugin_groups.json", {})
    tags = sorted(
        tag for tag, plugins in plugin_groups.items()
        if PLUGIN_ID in (plugins or [])
    )
    proxies = []
    proxy_dir = conf_dir / "proxy"
    if proxy_dir.exists():
        for path in sorted(proxy_dir.glob("*.config")):
            data = load_json_file(path, None)
            if not isinstance(data, dict):
                continue
            proxy_tags = data.get("Tags") or []
            matched_tags = sorted(set(tags).intersection(proxy_tags))
            if not matched_tags:
                continue
            proxies.append({
                "name": data.get("RootOrMatchingDomain") or path.stem,
                "file": path.name,
                "tags": proxy_tags,
                "matched_tags": matched_tags,
                "disabled": bool(data.get("Disabled", False)),
            })
    return {
        "plugin_id": PLUGIN_ID,
        "plugin_name": PLUGIN_NAME,
        "suggested_tag": PLUGIN_ID,
        "tags": tags,
        "proxies": proxies,
    }


def parse_token(token):
    token = token.strip().strip('"').strip("'")
    if not token or token.startswith("#"):
        return None
    if "#" in token:
        token = token.split("#", 1)[0].strip()
    try:
        if "/" in token:
            return ipaddress.ip_network(token, strict=False)
        ip = ipaddress.ip_address(token)
        mask = 32 if ip.version == 4 else 128
        return ipaddress.ip_network(f"{ip}/{mask}", strict=False)
    except ValueError:
        return None


def parse_plain(text):
    nets = []
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        line = line.replace(",", " ")
        for token in line.split():
            net = parse_token(token)
            if net is not None:
                nets.append(net)
    return nets


def parse_jsonish(text):
    nets = []
    stripped = text.lstrip()
    if stripped.startswith("["):
        data = json.loads(text)
        for item in data:
            if isinstance(item, str):
                net = parse_token(item)
            elif isinstance(item, dict):
                net = parse_token(item.get("cidr") or item.get("ip") or item.get("network") or "")
            else:
                net = None
            if net is not None:
                nets.append(net)
        return nets

    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            item = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(item, dict):
            net = parse_token(item.get("cidr") or item.get("ip") or item.get("network") or "")
            if net is not None:
                nets.append(net)
    return nets


def parse_blocklist(text, fmt):
    if fmt == "plain":
        return parse_plain(text)
    if fmt in ("json", "ndjson"):
        return parse_jsonish(text)
    try:
        nets = parse_jsonish(text)
        if nets:
            return nets
    except Exception:
        pass
    return parse_plain(text)


def write_source_cache(source_id, nets):
    unique = sorted({str(n) for n in nets}, key=lambda v: (":" in v, v))
    path = source_cache_path(source_id)
    tmp = path.with_suffix(".tmp")
    with tmp.open("w", encoding="utf-8") as handle:
        for item in unique:
            handle.write(item + "\n")
    os.replace(tmp, path)
    return len(unique)


def read_source_cache(source_id):
    path = source_cache_path(source_id)
    if not path.exists():
        return []
    return [net for net in parse_plain(path.read_text(encoding="utf-8"))]


def remove_stale_source_caches(old_cfg, new_cfg):
    old_ids = {str(clean_source(src)["id"]) for src in old_cfg.get("sources", [])}
    new_ids = {str(clean_source(src)["id"]) for src in new_cfg.get("sources", [])}
    for source_id in old_ids - new_ids:
        try:
            source_cache_path(source_id).unlink()
        except FileNotFoundError:
            pass


def fetch_source(src, settings):
    req = urllib.request.Request(src["url"], headers={"User-Agent": settings["user_agent"]})
    with urllib.request.urlopen(req, timeout=30) as response:
        body = response.read(10 * 1024 * 1024)
        charset = response.headers.get_content_charset() or "utf-8"
        text = body.decode(charset, errors="replace")
        nets = parse_blocklist(text, src["format"])
        if not nets:
            raise ValueError("no IP/CIDR entries found")
        count = write_source_cache(src["id"], nets)
        return response.status, count


def rebuild_matcher(cfg):
    prefixes_by_value = {}
    for src in cfg["sources"]:
        if src.get("enabled", True):
            for net in read_source_cache(src["id"]):
                prefixes_by_value[str(net)] = net
    prefixes = sorted(
        prefixes_by_value.values(),
        key=lambda net: (net.version, int(net.network_address), net.prefixlen),
    )
    with CONFIG_LOCK:
        STATE["prefixes"] = prefixes


def refresh_due_sources(force=False):
    with CONFIG_LOCK:
        cfg = load_config()
    changed = False
    settings = cfg["settings"]
    for idx, src in enumerate([clean_source(s) for s in cfg["sources"]]):
        cfg["sources"][idx] = src
        if not src.get("enabled", True):
            continue
        if not force and src.get("next_fetch", 0) > now():
            continue
        try:
            status, count = fetch_source(src, settings)
            src["last_status"] = f"ok:{status}"
            src["last_error"] = ""
            src["entry_count"] = count
        except Exception as exc:
            src["last_status"] = "error"
            src["last_error"] = str(exc)
        src["last_fetch"] = now()
        src["next_fetch"] = now() + src["interval_hours"] * 3600
        changed = True

    if changed:
        with CONFIG_LOCK:
            save_config(cfg)
        rebuild_matcher(cfg)
    return cfg


def scheduler():
    while STATE["running"]:
        try:
            refresh_due_sources(False)
        except Exception as exc:
            print(f"scheduler error: {exc}", file=sys.stderr)
        for _ in range(60):
            if not STATE["running"]:
                return
            time.sleep(1)


def client_ip_from_headers(headers, cfg):
    settings = cfg.get("settings", {})
    for header in settings.get("client_ip_headers", []):
        values = headers.get(header) or headers.get(header.lower()) or []
        if isinstance(values, str):
            values = [values]
        for value in values:
            candidate = value.split(",", 1)[0].strip()
            try:
                return ipaddress.ip_address(candidate)
            except ValueError:
                pass
    return None


def client_ip(payload, cfg):
    ip = client_ip_from_headers(payload.get("header", {}), cfg)
    if ip is not None:
        return ip
    remote = payload.get("remote_addr", "")
    host = remote.rsplit(":", 1)[0] if ":" in remote and not remote.startswith("[") else remote
    host = host.strip("[]")
    try:
        return ipaddress.ip_address(host)
    except ValueError:
        return None


def is_blocked(ip):
    if ip is None:
        return False
    with CONFIG_LOCK:
        prefixes = list(STATE["prefixes"])
    return any(ip in net for net in prefixes if net.version == ip.version)


def bump_stat(name, amount=1):
    with CONFIG_LOCK:
        STATE["stats"][name] = STATE["stats"].get(name, 0) + amount


def set_stat(name, value):
    with CONFIG_LOCK:
        STATE["stats"][name] = value


def stats_snapshot():
    with CONFIG_LOCK:
        stats = dict(STATE["stats"])
        stats["loaded_entries"] = len(STATE["prefixes"])
    return stats


class Handler(BaseHTTPRequestHandler):
    server_version = f"{PLUGIN_ID}/{VERSION[0]}.{VERSION[1]}.{VERSION[2]}"

    def log_message(self, fmt, *args):
        print("%s - %s" % (self.address_string(), fmt % args))

    def read_json(self):
        length = int(self.headers.get("Content-Length", "0") or "0")
        if length <= 0:
            return {}
        return json.loads(self.rfile.read(length).decode("utf-8"))

    def send_json(self, data, status=200):
        body = json.dumps(data, indent=2, sort_keys=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/") or "/"
        if path in (UI_PATH, UI_PATH + "/index.html"):
            return self.send_ui()
        if path == UI_PATH + "/api/config":
            with CONFIG_LOCK:
                cfg = load_config()
                total = len(STATE["prefixes"])
            return self.send_json({"config": cfg, "total_entries": total, "stats": stats_snapshot()})
        if path == UI_PATH + "/api/source":
            params = parse_qs(parsed.query)
            source_id = (params.get("id") or [""])[0]
            if not source_id:
                return self.send_json({"error": "missing source id"}, 400)
            entries = [str(net) for net in read_source_cache(source_id)]
            return self.send_json({"id": source_id, "entries": entries, "count": len(entries)})
        if path == UI_PATH + "/api/associations":
            return self.send_json(zoraxy_associations())
        self.send_error(404)

    def do_HEAD(self):
        path = urlparse(self.path).path.rstrip("/") or "/"
        if path in (UI_PATH, UI_PATH + "/index.html"):
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            return
        self.send_error(404)

    def do_POST(self):
        path = urlparse(self.path).path.rstrip("/") or "/"
        if path == DYNAMIC_SNIFF:
            return self.handle_sniff()
        if path == DYNAMIC_INGRESS:
            return self.handle_block()
        if path == UI_PATH + "/api/config":
            data = self.read_json()
            cfg = default_config()
            cfg["settings"].update(data.get("settings", {}))
            cfg["sources"] = [clean_source(s) for s in data.get("sources", [])]
            with CONFIG_LOCK:
                old_cfg = load_config()
                save_config(cfg)
            remove_stale_source_caches(old_cfg, cfg)
            rebuild_matcher(cfg)
            return self.send_json({"ok": True})
        if path == UI_PATH + "/api/refresh":
            cfg = refresh_due_sources(True)
            return self.send_json({"ok": True, "config": cfg, "total_entries": len(STATE["prefixes"])})
        self.send_error(404)

    def handle_sniff(self):
        bump_stat("sniff_total")
        try:
            payload = self.read_json()
            with CONFIG_LOCK:
                cfg = load_config()
            ip = client_ip(payload, cfg)
            event = {
                "time": now(),
                "ip": str(ip) if ip else "",
                "host": payload.get("host", ""),
                "uri": payload.get("request_uri", ""),
            }
            if ip is None:
                bump_stat("unknown_ip_total")
                bump_stat("pass_total")
                set_stat("last_pass", event)
                self.send_response(501)
                self.end_headers()
                self.wfile.write(b"SKIP")
                return
            if is_blocked(ip):
                bump_stat("drop_total")
                set_stat("last_drop", event)
                print(f"blocked sniff match ip={ip} host={payload.get('host','')} uri={payload.get('request_uri','')}")
                self.send_response(200)
                self.end_headers()
                self.wfile.write(b"OK")
            else:
                bump_stat("pass_total")
                set_stat("last_pass", event)
                self.send_response(501)
                self.end_headers()
                self.wfile.write(b"SKIP")
        except Exception as exc:
            bump_stat("error_total")
            print(f"sniff error: {exc}", file=sys.stderr)
            self.send_response(501)
            self.end_headers()
            self.wfile.write(b"SKIP")

    def handle_block(self):
        with CONFIG_LOCK:
            cfg = load_config()
        status = int(cfg.get("settings", {}).get("block_status", 403))
        body = b"Forbidden\n"
        self.send_response(status)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_ui(self):
        body = UI_HTML.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


