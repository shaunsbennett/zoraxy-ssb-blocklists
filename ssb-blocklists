def main():
    spec = parse_config_arg()
    base = plugin_dir()
    STATE["config_path"] = base / "config.json"
    STATE["cache_dir"] = base / "cache"
    STATE["cache_dir"].mkdir(exist_ok=True)

    with CONFIG_LOCK:
        cfg = load_config()
    rebuild_matcher(cfg)
    threading.Thread(target=scheduler, daemon=True).start()

    def stop(_signum, _frame):
        STATE["running"] = False
        raise SystemExit(0)

    signal.signal(signal.SIGTERM, stop)
    signal.signal(signal.SIGINT, stop)

    port = int(spec.get("port", 0))
    if port <= 0:
        raise SystemExit("invalid configure port")
    with socketserver.ThreadingTCPServer(("127.0.0.1", port), Handler) as httpd:
        httpd.daemon_threads = True
        print(f"{PLUGIN_NAME} listening on 127.0.0.1:{port}")
        httpd.serve_forever()


if __name__ == "__main__":
    main()
